    {
      "name": "06 Add Product",
      "event": [
        {
          "listen": "test",
          "script": {
            "id": "5616ea17-68d0-4fcb-9ffd-4af0694e01b7",
            "exec": [
              "pm.test(\"Product creation is accepted\", function () {\r",
              "    pm.expect(pm.response.code).to.be.oneOf([\r",
              "        200,\r",
              "        201\r",
              "    ]);\r",
              "});\r",
              "\r",
              "pm.test(\"Created product matches request\", function () {\r",
              "    const jsonData = pm.response.json();\r",
              "\r",
              "    pm.expect(jsonData.title)\r",
              "        .to.equal(\"QA Test Product\");\r",
              "\r",
              "    pm.expect(jsonData.price)\r",
              "        .to.equal(99.9);\r",
              "\r",
              "    pm.expect(jsonData.id)\r",
              "        .to.be.a(\"number\");\r",
              "});"
            ],
            "type": "text/javascript",
            "packages": {},
            "requests": {}
          }
        }
      ],
